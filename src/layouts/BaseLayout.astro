---
import "../styles/global.css";
import AccessibilityMenu from "../components/AccessibilityMenu.astro";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Portal de Editais, parte do Projeto Horizon, com oportunidades de fomento à pesquisa, ciência e extensão.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0, viewport-fit=cover"
		/>
		<link
			rel="icon"
			type="image/svg+xml"
			href={`${import.meta.env.BASE_URL}/favicon.svg`}
		/>
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
			rel="stylesheet"
		/>

		<!-- Anti-FOUC Theme Script -->
		<script is:inline>
			const theme = localStorage.getItem("theme");
			const contrast = localStorage.getItem("a11y-contrast");
			const dyslexia = localStorage.getItem("a11y-dyslexia");
			const links = localStorage.getItem("a11y-links");
			const animations = localStorage.getItem("a11y-animations");
			const fontSize = localStorage.getItem("a11y-font-size");

			const doc = document.documentElement;

			if (
				theme === "dark" ||
				(!theme &&
					window.matchMedia("(prefers-color-scheme: dark)").matches)
			) {
				doc.classList.add("dark");
			}

			if (contrast === "true") doc.classList.add("contrast");
			if (dyslexia === "true") doc.classList.add("dyslexia-font");
			if (links === "true") doc.classList.add("highlight-links");
			if (animations === "true") doc.classList.add("stop-animations");
			if (fontSize && fontSize !== "base")
				doc.classList.add(`text-${fontSize}`);
		</script>
	</head>
	<body
		class="min-h-screen flex flex-col selection:bg-primary-200 selection:text-primary-900 dark:selection:bg-primary-800 dark:selection:text-primary-100"
	>
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-6 focus:py-3 focus:bg-primary-600 focus:text-white focus:font-bold focus:rounded-xl focus:shadow-2xl focus:outline-none focus:ring-4 focus:ring-primary-500/50 transition-all"
		>
			Pular para o conteúdo principal
		</a>
		<slot />
		<AccessibilityMenu />
		<script is:inline>
			(function () {
				function applyFechandoStatus() {
					var hoje = new Date();
					hoje.setHours(0, 0, 0, 0);
					var badges = document.querySelectorAll("[data-edital-status-badge]");
					var fechandoClassCard =
						"px-2 py-0.5 rounded text-[10px] font-bold border uppercase tracking-wider bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border-amber-200 dark:border-amber-500/20";
					var fechandoClassPage =
						"px-3 py-1 rounded-full text-xs font-bold border uppercase tracking-wider bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border-amber-200 dark:border-amber-500/20";
					badges.forEach(function (badge) {
						var parent = badge.closest("[data-encerramento]");
						if (!parent || !parent.dataset.encerramento || parent.dataset.status !== "aberto") return;
						var dataFim = new Date(parent.dataset.encerramento);
						dataFim.setHours(0, 0, 0, 0);
						if (dataFim >= hoje) return;
						parent.dataset.status = "fechando";
						badge.textContent = "fechando";
						badge.className =
							badge.getAttribute("data-edital-status-size") === "page"
								? fechandoClassPage
								: fechandoClassCard;
					});
				}
				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", applyFechandoStatus);
				} else {
					applyFechandoStatus();
				}
			})();
		</script>
	</body>
</html>
