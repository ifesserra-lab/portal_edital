---

---

<div class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3">
    <!-- Accessibility Menu (Floating) -->
    <div
        id="a11y-menu"
        class="hidden flex-col gap-2 p-2 glass rounded-2xl shadow-2xl border border-primary-200/50 animate-in slide-in-from-bottom-4 fade-in duration-300"
    >
        <button
            id="toggle-contrast"
            class="flex items-center gap-3 w-40 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-sm font-bold text-slate-700 dark:text-slate-300"
            title="Alternar Alto Contraste"
        >
            <span
                class="w-5 h-5 flex items-center justify-center border-2 border-current rounded-full text-xs"
                >C</span
            >
            Alto Contraste
        </button>
        <button
            id="toggle-dark"
            class="flex items-center gap-3 w-40 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-sm font-bold text-slate-700 dark:text-slate-300"
            title="Alternar Modo Escuro"
        >
            <span class="w-5 h-5">🌙</span>
            Tema
        </button>
    </div>

    <!-- Trigger Button -->
    <button
        id="a11y-trigger"
        class="w-14 h-14 rounded-full bg-primary-600 text-white shadow-xl hover:bg-primary-500 hover:scale-110 active:scale-95 transition-all flex items-center justify-center group focus-visible:ring-4 focus-visible:ring-primary-400"
        aria-label="Opções de Acessibilidade"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 group-hover:rotate-12 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
            ></path>
        </svg>
    </button>
</div>

<script>
    const trigger = document.getElementById("a11y-trigger");
    const menu = document.getElementById("a11y-menu");
    const contrastBtn = document.getElementById("toggle-contrast");
    const darkBtn = document.getElementById("toggle-dark");

    // Toggle Menu
    trigger?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
        menu?.classList.toggle("flex");
    });

    // Dark Mode Logic
    darkBtn?.addEventListener("click", () => {
        document.documentElement.classList.toggle("dark");
        const isDark = document.documentElement.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
    });

    // High Contrast Logic
    contrastBtn?.addEventListener("click", () => {
        document.documentElement.classList.toggle("contrast");
        const isContrast =
            document.documentElement.classList.contains("contrast");
        localStorage.setItem("contrast", isContrast ? "enabled" : "disabled");
    });

    // Close menu when clicking outside
    document.addEventListener("click", (e) => {
        if (
            !trigger?.contains(e.target as Node) &&
            !menu?.contains(e.target as Node)
        ) {
            menu?.classList.add("hidden");
            menu?.classList.remove("flex");
        }
    });
</script>
