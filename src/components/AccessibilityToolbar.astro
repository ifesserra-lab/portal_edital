---

---

<div class="fixed bottom-6 right-6 z-[100] flex flex-col gap-4 items-end">
    <!-- Accessibility Menu (Floating) -->
    <div
        id="a11y-menu"
        class="hidden flex-col gap-2 p-2 glass rounded-2xl shadow-2xl border border-white/20 animate-in slide-in-from-bottom-4 fade-in duration-300"
    >
        <button
            id="toggle-contrast"
            class="flex items-center gap-3 w-48 px-4 py-3 rounded-xl hover:bg-primary-100 dark:hover:bg-primary-800 transition-colors text-xs font-black uppercase tracking-widest text-primary-900 dark:text-primary-100 cursor-pointer"
            title="Alternar Alto Contraste"
        >
            <span
                class="w-5 h-5 flex items-center justify-center border-2 border-current rounded-full"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3 h-3"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><path
                        d="M12 18a6 6 0 0 0 0-12v12z"></path></svg
                >
            </span>
            Alto Contraste
        </button>
        <button
            id="toggle-dark"
            class="flex items-center gap-3 w-48 px-4 py-3 rounded-xl hover:bg-primary-100 dark:hover:bg-primary-800 transition-colors text-xs font-black uppercase tracking-widest text-primary-900 dark:text-primary-100 cursor-pointer"
            title="Alternar Modo Escuro"
        >
            <span class="w-5 h-5 flex items-center justify-center">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg
                >
            </span>
            Tema
        </button>
        <button
            id="toggle-font"
            class="flex items-center gap-3 w-48 px-4 py-3 rounded-xl hover:bg-primary-100 dark:hover:bg-primary-800 transition-colors text-xs font-black uppercase tracking-widest text-primary-900 dark:text-primary-100 cursor-pointer"
            title="Alternar Tamanho da Fonte (Baixa Visão)"
        >
            <span
                class="w-5 h-5 flex items-center justify-center font-heading text-base font-black"
                >A+</span
            >
            Baixa Visão
        </button>
    </div>

    <!-- Trigger Button -->
    <button
        id="a11y-trigger"
        class="w-14 h-14 rounded-full bg-cta-700 text-white shadow-2xl shadow-cta-500/30 hover:bg-cta-600 hover:scale-110 active:scale-95 transition-all flex items-center justify-center group focus-visible:ring-4 focus-visible:ring-cta-500/50 cursor-pointer"
        aria-label="Opções de Acessibilidade"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 group-hover:rotate-12 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
            ></path>
        </svg>
    </button>
</div>

<script>
    const trigger = document.getElementById("a11y-trigger");
    const menu = document.getElementById("a11y-menu");
    const contrastBtn = document.getElementById("toggle-contrast");
    const darkBtn = document.getElementById("toggle-dark");
    const fontBtn = document.getElementById("toggle-font");

    // Toggle Menu
    trigger?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
        menu?.classList.toggle("flex");
    });

    // Dark Mode Logic
    darkBtn?.addEventListener("click", () => {
        document.documentElement.classList.toggle("dark");
        const isDark = document.documentElement.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
    });

    // High Contrast Logic
    contrastBtn?.addEventListener("click", () => {
        document.documentElement.classList.toggle("contrast");
        const isContrast =
            document.documentElement.classList.contains("contrast");
        localStorage.setItem("contrast", isContrast ? "enabled" : "disabled");
    });

    // Font Scaling Logic (Low Vision)
    fontBtn?.addEventListener("click", () => {
        document.documentElement.classList.toggle("large-text");
        const isLarge =
            document.documentElement.classList.contains("large-text");
        localStorage.setItem("font-size", isLarge ? "large" : "normal");
    });

    // Close menu when clicking outside
    document.addEventListener("click", (e) => {
        if (
            !trigger?.contains(e.target as Node) &&
            !menu?.contains(e.target as Node)
        ) {
            menu?.classList.add("hidden");
            menu?.classList.remove("flex");
        }
    });
</script>
