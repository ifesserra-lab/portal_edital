---

---

<header class="sticky top-0 z-50 w-full glass-dark py-1">
    <div class="container flex h-20 items-center justify-between">
        <a
            href={import.meta.env.BASE_URL}
            class="group flex items-center space-x-3 focus:outline-none px-2 py-1 rounded-2xl transition-all"
        >
            <div
                class="w-10 h-10 bg-cta-700 rounded-xl flex items-center justify-center shadow-lg shadow-cta-500/20 group-hover:bg-cta-600 transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6 text-white"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"
                    ></path></svg
                >
            </div>
            <span class="text-2xl font-black tracking-tight text-white">
                Portal de <span
                    class="text-cta-500 group-hover:text-cta-400 transition-colors"
                    >Editais</span
                >
            </span>
        </a>

        <nav class="flex items-center space-x-1 sm:space-x-8">
            <a
                href={`${import.meta.env.BASE_URL}/sobre/`}
                class="text-sm font-bold uppercase tracking-widest text-primary-200 hover:text-white transition-all px-4 py-2 rounded-xl hover:bg-white/5"
            >
                Sobre
            </a>
            <a
                href="https://github.com/ifesserra-lab/portal_edital"
                target="_blank"
                class="hidden sm:inline-flex h-12 items-center justify-center rounded-2xl bg-cta-700 px-6 text-sm font-black uppercase tracking-widest text-white shadow-xl shadow-cta-500/20 hover:bg-cta-600 hover:-translate-y-1 active:scale-95 transition-all"
            >
                GitHub
            </a>
        </nav>
    </div>
</header>
