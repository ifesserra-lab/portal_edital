---
import type { CollectionEntry } from "astro:content";

interface Props {
    edital: CollectionEntry<"editais">;
}

const { edital } = Astro.props;
const { data, id } = edital;

const statusColors = {
    aberto: "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400 border-emerald-200 dark:border-emerald-500/20",
    encerrado:
        "bg-slate-100 text-slate-700 dark:bg-slate-500/10 dark:text-slate-400 border-slate-200 dark:border-slate-500/20",
    suspenso:
        "bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border-amber-200 dark:border-amber-500/20",
    resultado:
        "bg-blue-100 text-blue-700 dark:bg-blue-500/10 dark:text-blue-400 border-blue-200 dark:border-blue-500/20",
};
---

<article
    class="group relative flex flex-col p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-xl hover:border-primary-200 dark:hover:border-primary-500/30 transition-all duration-300 active:scale-[0.98]"
    data-testid="edital-card"
    data-status={data.status}
>
    <div class="flex items-center justify-between mb-4">
        <span
            class={`px-2.5 py-0.5 rounded-full text-xs font-bold border uppercase tracking-wider ${statusColors[data.status]}`}
            data-testid="edital-status"
        >
            {data.status}
        </span>
        <span
            class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-tight"
        >
            {data.categoria}
        </span>
    </div>

    <h3
        class="text-xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors line-clamp-2"
        data-testid="edital-titulo"
    >
        <a
            href={`/editais/${id}`}
            class="after:absolute after:inset-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-lg"
        >
            {data.nome}
        </a>
    </h3>

    <p
        class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-6 line-clamp-3 text-pretty"
    >
        {data.descrição}
    </p>

    <div
        class="mt-auto pt-4 border-t border-slate-100 dark:border-slate-800 flex flex-col gap-2"
    >
        <div
            class="flex items-center text-xs text-slate-500 dark:text-slate-500 font-medium"
        >
            <span class="w-20 shrink-0">Órgão:</span>
            <span class="text-slate-900 dark:text-slate-300"
                >{data.orgão_fomento}</span
            >
        </div>
        <div
            class="flex items-center text-xs text-slate-500 dark:text-slate-500 font-medium"
        >
            <span class="w-20 shrink-0">Encerramento:</span>
            <span class="text-slate-900 dark:text-slate-300 font-bold"
                >{
                    new Date(data.data_encerramento).toLocaleDateString("pt-BR")
                }</span
            >
        </div>
    </div>
</article>
