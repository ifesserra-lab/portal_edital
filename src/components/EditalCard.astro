---
import type { CollectionEntry } from "astro:content";

interface Props {
    edital: CollectionEntry<"editais">;
}

const { edital } = Astro.props;
const { data, id } = edital;

const statusColors = {
    aberto: "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400 border-emerald-200 dark:border-emerald-500/20",
    encerrado:
        "bg-slate-100 text-slate-700 dark:bg-slate-500/10 dark:text-slate-400 border-slate-200 dark:border-slate-500/20",
    suspenso:
        "bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400 border-amber-200 dark:border-amber-500/20",
    resultado:
        "bg-blue-100 text-blue-700 dark:bg-blue-500/10 dark:text-blue-400 border-blue-200 dark:border-blue-500/20",
};
---

<article
    class="card-minimal group relative flex flex-col p-6 h-full"
    data-testid="edital-card"
    data-status={data.status}
    data-category={data.categoria}
    data-search-index={`${data.nome} ${data.descrição} ${data.orgão_fomento}`.toLowerCase()}
>
    <div class="flex items-center justify-between mb-4">
        <span
            class={`px-2 py-0.5 rounded text-[10px] font-bold border uppercase tracking-wider ${statusColors[data.status]}`}
            data-testid="edital-status"
        >
            {data.status}
        </span>
        <span
            class="text-[10px] font-medium text-primary-500 uppercase tracking-widest bg-primary-100 dark:bg-white/5 px-2 py-0.5 rounded"
        >
            {data.categoria}
        </span>
    </div>

    <h3
        class="text-lg font-semibold text-primary-900 dark:text-white mb-3 group-hover:text-cta-600 transition-colors duration-200 line-clamp-2 leading-snug"
        data-testid="edital-titulo"
    >
        <a
            href={`${import.meta.env.BASE_URL}/editais/${id}/`}
            class="after:absolute after:inset-0 focus:outline-none"
        >
            {data.nome}
        </a>
    </h3>

    <p
        class="text-primary-600 dark:text-primary-400 text-sm leading-relaxed mb-6 line-clamp-3"
    >
        {data.descrição}
    </p>

    <div
        class="mt-auto pt-4 border-t border-primary-100 dark:border-white/5 flex flex-col gap-2"
    >
        <div
            class="flex items-center justify-between text-[11px] font-medium uppercase tracking-tight"
        >
            <span class="text-primary-400">Órgão</span>
            <span class="text-primary-700 dark:text-primary-300"
                >{data.orgão_fomento}</span
            >
        </div>
        <div
            class="flex items-center justify-between text-[11px] font-medium uppercase tracking-tight"
        >
            <span class="text-primary-400">Encerramento</span>
            <span class="text-cta-600 font-bold"
                >{
                    new Date(data.data_encerramento).toLocaleDateString("pt-BR")
                }</span
            >
        </div>
    </div>
</article>
