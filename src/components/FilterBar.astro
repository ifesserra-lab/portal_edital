---
import { getSiteCategories } from "../utils/category.js";

interface Props {
    hideStatus?: boolean;
}

const { hideStatus = false } = Astro.props;
const categories = [
    { id: "all", label: "Todos" },
    ...getSiteCategories().map((category) => ({
        id: category.id,
        label: category.label
    })),
];

const statuses = [
    { id: "all", label: "Todos os Status" },
    { id: "aberto", label: "Abertos" },
    { id: "fechando", label: "Fechando" },
    { id: "encerrado", label: "Encerrados" },
];
---

<div class="flex flex-col gap-6 mb-12">
    <div class="w-full max-w-2xl">
        <label for="search-input" class="sr-only">Buscar editais</label>
        <div class="relative group">
            <div
                class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none transition-colors group-focus-within:text-cta-600"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 text-primary-400 group-focus-within:text-cta-600 transition-colors"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </div>
            <input
                type="search"
                id="search-input"
                class="w-full pl-11 pr-4 py-3 rounded-lg border border-primary-200 dark:border-white/10 bg-white dark:bg-primary-900/40 text-primary-900 dark:text-white placeholder-primary-400 focus:outline-none focus:border-cta-500 focus:ring-4 focus:ring-cta-500/5 transition-all text-sm font-medium"
                placeholder="Busque por título ou palavra-chave..."
            />
        </div>
    </div>

    <div class="flex flex-wrap items-center gap-2">
        <span
            class="text-[10px] font-bold text-primary-400 uppercase tracking-widest mr-2"
            >Categorias</span
        >
        {
            categories.map((cat) => (
                <button
                    data-filter-category={cat.id}
                    class="filter-btn px-4 py-1.5 rounded-md text-[11px] font-semibold uppercase tracking-wider border transition-all active:scale-95 cursor-pointer"
                >
                    {cat.label}
                </button>
            ))
        }
    </div>

    {
        !hideStatus && (
            <div class="flex flex-wrap items-center gap-2">
                <span class="text-[10px] font-bold text-primary-400 uppercase tracking-widest mr-2">
                    Status
                </span>
                {statuses.map((status) => (
                    <button
                        data-filter-status={status.id}
                        class="filter-btn px-4 py-1.5 rounded-md text-[11px] font-semibold uppercase tracking-wider border transition-all active:scale-95 cursor-pointer"
                    >
                        {status.label}
                    </button>
                ))}
            </div>
        )
    }
</div>

<script>
    function updateFilters() {
        const url = new URL(window.location.href);
        const category = url.searchParams.get("categoria") || "all";
        const status = url.searchParams.get("status") || "all";
        const keyword = (url.searchParams.get("q") || "").toLowerCase();

        const searchInput = document.getElementById(
            "search-input",
        ) as HTMLInputElement;
        if (searchInput && searchInput.value.toLowerCase() !== keyword) {
            searchInput.value = url.searchParams.get("q") || "";
        }

        // Update buttons UI
        document.querySelectorAll("[data-filter-category]").forEach((btn) => {
            const isSelected =
                btn.getAttribute("data-filter-category") === category;
            btn.classList.toggle("bg-cta-600", isSelected);
            btn.classList.toggle("text-white", isSelected);
            btn.classList.toggle("border-cta-600", isSelected);

            btn.classList.toggle("bg-white", !isSelected);
            btn.classList.toggle("dark:bg-transparent", !isSelected);
            btn.classList.toggle("text-primary-600", !isSelected);
            btn.classList.toggle("dark:text-primary-400", !isSelected);
            btn.classList.toggle("border-primary-200", !isSelected);
            btn.classList.toggle("dark:border-white/10", !isSelected);
        });

        document.querySelectorAll("[data-filter-status]").forEach((btn) => {
            const isSelected =
                btn.getAttribute("data-filter-status") === status;
            btn.classList.toggle("bg-primary-900", isSelected);
            btn.classList.toggle("dark:bg-white", isSelected);
            btn.classList.toggle("text-white", isSelected);
            btn.classList.toggle("dark:text-primary-900", isSelected);
            btn.classList.toggle("border-primary-900", isSelected);
            btn.classList.toggle("dark:border-white", isSelected);

            btn.classList.toggle("bg-white", !isSelected);
            btn.classList.toggle("dark:bg-transparent", !isSelected);
            btn.classList.toggle("text-primary-600", !isSelected);
            btn.classList.toggle("dark:text-primary-400", !isSelected);
            btn.classList.toggle("border-primary-200", !isSelected);
            btn.classList.toggle("dark:border-white/10", !isSelected);
        });

        // Client-side filtering of the list
        const cards = document.querySelectorAll(".card-minimal");
        cards.forEach((card) => {
            const cardCategory = card.getAttribute("data-category");
            const cardStatus = card.getAttribute("data-status");
            const cardText = card.getAttribute("data-search-index") || "";

            const categoryMatch =
                category === "all" || cardCategory === category;
            const statusMatch = status === "all" || cardStatus === status;
            const keywordMatch = keyword === "" || cardText.includes(keyword);

            if (categoryMatch && statusMatch && keywordMatch) {
                // @ts-ignore
                card.style.display = "flex";
            } else {
                // @ts-ignore
                card.style.display = "none";
            }
        });
    }

    document.querySelectorAll(".filter-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            const url = new URL(window.location.href);
            const cat = btn.getAttribute("data-filter-category");
            const stat = btn.getAttribute("data-filter-status");

            if (cat) url.searchParams.set("categoria", cat);
            if (stat) url.searchParams.set("status", stat);

            window.history.pushState({}, "", url);
            updateFilters();
        });
    });

    const searchInput = document.getElementById("search-input");
    if (searchInput) {
        let debounceTimer: ReturnType<typeof setTimeout>;
        searchInput.addEventListener("input", (e) => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                const url = new URL(window.location.href);
                const val = (e.target as HTMLInputElement).value.trim();

                if (val) {
                    url.searchParams.set("q", val);
                } else {
                    url.searchParams.delete("q");
                }

                window.history.pushState({}, "", url);
                updateFilters();
            }, 300);
        });
    }

    // Handle browser back/forward
    window.addEventListener("popstate", updateFilters);

    // Initial check
    updateFilters();
</script>
