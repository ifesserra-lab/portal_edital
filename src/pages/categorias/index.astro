---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import EditalCard from "../../components/EditalCard.astro";
import { getCollection } from "astro:content";
import { getCategoryLabel, getSiteCategories } from "../../utils/category.js";

const editais = await getCollection("editais");
const configuredCategories = getSiteCategories();
const categoryOrder = new Map(
    configuredCategories.map((category, index) => [category.id, category.order ?? index])
);

// Agrupar por categoria e ordenar
const categoriasUnicas = [
    ...new Set(editais.map((e) => e.data.categoria)),
].sort((left, right) => {
    const leftOrder = categoryOrder.get(left) ?? 999;
    const rightOrder = categoryOrder.get(right) ?? 999;

    if (leftOrder !== rightOrder) {
        return leftOrder - rightOrder;
    }

    return getCategoryLabel(left).localeCompare(getCategoryLabel(right), "pt-BR");
});

const editaisAgrupados = categoriasUnicas.map((categoria) => {
    return {
        categoria,
        label: getCategoryLabel(categoria),
        editais: editais
            .filter((e) => e.data.categoria === categoria)
            .sort((a, b) => a.data.nome.localeCompare(b.data.nome)), // Ordem alfabética pelo nome
    };
});
---

<BaseLayout title="Portal de Editais — Categorias">
    <Header />
    <main id="main-content" class="flex-grow py-8 sm:py-16" tabindex="-1">
        <div class="container">
            <section class="max-w-4xl mx-auto mb-16 px-4">
                <div
                    class="inline-flex items-center space-x-2 bg-cta-500/10 border border-cta-500/20 rounded-full px-4 py-1.5 mb-6"
                >
                    <span class="flex h-2 w-2 rounded-full bg-cta-500"></span>
                    <span
                        class="text-xs font-bold text-cta-500 uppercase tracking-widest"
                        >Catálogo Completo</span
                    >
                </div>
                <h1
                    class="text-4xl sm:text-5xl font-black text-primary-900 dark:text-white mb-6 leading-tight"
                >
                    Editais por <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-cta-500 to-blue-400"
                        >Categoria</span
                    >
                </h1>
                <p
                    class="text-xl sm:text-2xl text-primary-600 dark:text-primary-300 font-medium"
                >
                    Explore todas as oportunidades organizadas sistematicamente
                    para facilitar a sua busca.
                </p>
            </section>

            <div class="space-y-24 max-w-5xl mx-auto px-4">
                {
                    editaisAgrupados.map((grupo) => (
                        <section>
                            <div class="flex items-center gap-6 mb-10">
                                <h2 class="text-2xl sm:text-3xl font-extrabold text-primary-900 dark:text-white uppercase tracking-[0.15em]">
                                    {grupo.label}
                                </h2>
                                <div class="h-1 flex-grow bg-primary-100 dark:bg-white/10 rounded-full" />
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
                                {grupo.editais.map((edital) => (
                                    <div class="edital-item">
                                        <EditalCard edital={edital} />
                                    </div>
                                ))}
                            </div>
                        </section>
                    ))
                }

                {
                    editaisAgrupados.length === 0 && (
                        <div class="flex flex-col items-center justify-center py-24 px-6 glass rounded-[2.5rem] border-dashed border-2 border-slate-300 dark:border-slate-800">
                            <div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-2xl flex items-center justify-center mb-6 rotate-3">
                                <span class="text-3xl font-serif italic text-slate-400">
                                    ?
                                </span>
                            </div>
                            <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">
                                Sem editais disponíveis
                            </h3>
                            <p class="text-slate-500 dark:text-slate-400 text-center max-w-xs">
                                Nossas bases de dados não possuem editais no
                                momento.
                            </p>
                        </div>
                    )
                }
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>
