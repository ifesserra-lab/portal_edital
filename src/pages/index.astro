---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EditalCard from "../components/EditalCard.astro";
import FilterBar from "../components/FilterBar.astro";
import { getCollection } from "astro:content";

const todosEditais = await getCollection("editais");
const editais = todosEditais.filter((e) => e.data.status === "aberto");
const abertosCount = editais.length;
const totalCount = editais.length;
---

<BaseLayout title="Portal de Editais — Início">
	<Header />
	<main id="main-content" class="flex-grow py-8 sm:py-16" tabindex="-1">
		<div class="container">
			<!-- Innovative Hero -->
			<section
				class="relative overflow-hidden rounded-3xl bg-primary-950 border border-white/10 px-6 py-12 sm:px-16 sm:py-24 shadow-2xl mb-20 group"
			>
				<!-- Animated background glow -->
				<div
					class="absolute -top-40 -right-40 w-[40rem] h-[40rem] bg-cta-600/20 rounded-full blur-[120px] animate-pulse pointer-events-none group-hover:scale-110 transition-transform duration-1000"
				>
				</div>
				<div
					class="absolute top-20 left-10 w-80 h-80 bg-primary-500/10 rounded-full blur-[100px] pointer-events-none"
				>
				</div>

				<div class="relative z-10 max-w-3xl">
					<div
						class="inline-flex items-center space-x-2 bg-cta-500/10 border border-cta-500/20 rounded-full px-4 py-1.5 mb-8 animate-in fade-in slide-in-from-left-4 duration-700"
					>
						<span class="flex h-2 w-2 rounded-full bg-cta-500"
						></span>
						<span
							class="text-xs font-bold text-cta-500 uppercase tracking-widest"
							>Plataforma de Fomento</span
						>
					</div>

					<h1
						class="text-5xl sm:text-7xl font-black text-white tracking-tight leading-[1.05] mb-8 animate-in fade-in slide-in-from-bottom-4 delay-100 duration-700 text-balance"
					>
						Transformando <span
							class="text-transparent bg-clip-text bg-gradient-to-r from-cta-500 to-blue-400"
							>Ciência</span
						> em Impacto Real
					</h1>

					<p
						class="text-xl sm:text-2xl text-primary-300/80 font-medium leading-relaxed mb-12 animate-in fade-in slide-in-from-bottom-4 delay-200 duration-700 text-pretty max-w-xl"
					>
						Acesse as melhores oportunidades de fomento e impulsione
						seus projetos de pesquisa e inovação.
					</p>

					<div
						class="flex flex-wrap items-center gap-6 animate-in fade-in slide-in-from-bottom-4 delay-300 duration-700"
					>
						<a
							href="#editais"
							class="btn-cta overflow-hidden group relative"
						>
							<span class="relative z-10">Explorar Editais</span>
							<div
								class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/20 to-white/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000"
							>
							</div>
						</a>

						<div class="flex -space-x-3 items-center">
							<div
								class="w-10 h-10 rounded-full border-2 border-primary-950 bg-primary-900 flex items-center justify-center text-xs font-bold text-white shadow-lg"
							>
								+
							</div>
							<div
								class="w-10 h-10 rounded-full border-2 border-primary-950 bg-cta-600 flex items-center justify-center text-xs font-bold text-white shadow-lg"
							>
								F
							</div>
							<div
								class="pl-6 text-sm font-semibold text-primary-400"
							>
								<span class="text-white"
									>{abertosCount} Ativos</span
								> hoje
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="editais" class="scroll-mt-24">
				<div
					class="flex flex-col sm:flex-row sm:items-end justify-between mb-12 gap-4"
				>
					<div class="space-y-2">
						<h2
							class="text-3xl sm:text-4xl font-extrabold text-primary-900 dark:text-white leading-none"
						>
							Explore Oportunidades
						</h2>
						<div class="h-1.5 w-20 bg-cta-600 rounded-full"></div>
					</div>
					<p
						class="text-primary-500 dark:text-primary-400 font-medium sm:text-lg"
					>
						Oportunidades atualizadas em tempo real.
					</p>
				</div>

				<FilterBar hideStatus={true} />

				<div data-pagefind-body>
					{
						totalCount > 0 ? (
							<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-10">
								{editais.map((edital) => (
									<div class="edital-item">
										<EditalCard edital={edital} />
									</div>
								))}
							</div>
						) : (
							<div class="flex flex-col items-center justify-center py-24 px-6 glass rounded-[2.5rem] border-dashed border-2 border-slate-300 dark:border-slate-800">
								<div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-2xl flex items-center justify-center mb-6 rotate-3">
									<span class="text-3xl font-serif italic text-slate-400">
										?
									</span>
								</div>
								<h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">
									Sem editais no momento
								</h3>
								<p class="text-slate-500 dark:text-slate-400 text-center max-w-xs">
									Nossa equipe está preparando novas
									oportunidades. Volte em breve!
								</p>
							</div>
						)
					}
				</div>
			</section>
		</div>
	</main>
	<Footer />
</BaseLayout>
