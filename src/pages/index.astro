---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EditalCard from "../components/EditalCard.astro";
import FilterBar from "../components/FilterBar.astro";
import { getCollection } from "astro:content";

const editais = await getCollection("editais");
const abertosCount = editais.filter((e) => e.data.status === "aberto").length;
const totalCount = editais.length;
---

<BaseLayout title="Portal de Editais — Início">
	<Header />
	<main id="main-content" class="flex-grow py-12 sm:py-24" tabindex="-1">
		<div class="container">
			<!-- Minimalist Hero -->
			<section class="max-w-4xl mb-24">
				<div
					class="inline-flex items-center space-x-2 bg-cta-50 dark:bg-cta-500/10 rounded-full px-3 py-1 mb-6 animate-in fade-in slide-in-from-left-4 duration-500"
				>
					<span class="flex h-1.5 w-1.5 rounded-full bg-cta-600"
					></span>
					<span
						class="text-[10px] font-bold text-cta-600 uppercase tracking-widest"
						>Transparência & Ciência</span
					>
				</div>

				<h1
					class="text-5xl sm:text-7xl font-bold text-primary-900 dark:text-white tracking-tight leading-[1.1] mb-8 animate-in fade-in slide-in-from-bottom-4 delay-100 duration-500"
				>
					Simplicidade no acesso ao <span class="text-cta-600"
						>fomento</span
					>.
				</h1>

				<p
					class="text-lg sm:text-xl text-primary-600 dark:text-primary-400 font-normal leading-relaxed mb-10 animate-in fade-in slide-in-from-bottom-4 delay-200 duration-500 max-w-2xl"
				>
					Acompanhe editais de pesquisa, inovação e extensão de forma
					direta e organizada. Informação clara para quem constrói o
					futuro.
				</p>

				<div
					class="flex items-center gap-4 animate-in fade-in slide-in-from-bottom-4 delay-300 duration-500"
				>
					<a href="#editais" class="btn-cta"> Ver Oportunidades </a>
					<div
						class="h-1 w-12 bg-primary-100 dark:bg-white/10 rounded-full hidden sm:block"
					>
					</div>
					<div class="text-sm font-medium text-primary-500">
						<span class="text-primary-900 dark:text-white font-bold"
							>{abertosCount} Ativos</span
						> atualmente
					</div>
				</div>
			</section>

			<section id="editais" class="scroll-mt-20">
				<div class="flex flex-col mb-10">
					<h2
						class="text-2xl sm:text-3xl font-bold text-primary-900 dark:text-white mb-2"
					>
						Oportunidades
					</h2>
					<p
						class="text-primary-500 dark:text-primary-400 font-medium"
					>
						Role para explorar os editais disponíveis.
					</p>
				</div>

				<FilterBar />

				<div data-pagefind-body>
					{
						totalCount > 0 ? (
							<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-10">
								{editais.map((edital) => (
									<div class="edital-item">
										<EditalCard edital={edital} />
									</div>
								))}
							</div>
						) : (
							<div class="flex flex-col items-center justify-center py-24 px-6 glass rounded-[2.5rem] border-dashed border-2 border-slate-300 dark:border-slate-800">
								<div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-2xl flex items-center justify-center mb-6 rotate-3">
									<span class="text-3xl font-serif italic text-slate-400">
										?
									</span>
								</div>
								<h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">
									Sem editais no momento
								</h3>
								<p class="text-slate-500 dark:text-slate-400 text-center max-w-xs">
									Nossa equipe está preparando novas
									oportunidades. Volte em breve!
								</p>
							</div>
						)
					}
				</div>
			</section>
		</div>
	</main>
	<Footer />
</BaseLayout>
